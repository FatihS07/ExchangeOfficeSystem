<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="850" Width="950"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="30,30,15,30" Padding="40,30" 
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="NBP CURRENCY EXCHANGE" FontSize="22" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Currency Code (e.g., USD, EUR):" FontSize="14" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCurrencyCode" Height="40" FontSize="16" Padding="10,6" 
                         CharacterCasing="Upper" BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="btnGetRate" Content="Get Rate" Height="40" FontSize="16" FontWeight="Bold" 
                        Foreground="White" Background="#2563EB" BorderThickness="0" Click="btnGetRate_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="txtResult" Text="Ready." FontSize="14" Margin="0,15,0,5" Foreground="#6B7280" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtBuyRate" Text="Buy (Bid): -" FontSize="18" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBlock x:Name="txtSellRate" Text="Sell (Ask): -" FontSize="18" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center"/>

                <Button x:Name="btnHistory" Content="Show 7-Day History" Height="30" Width="150" FontSize="12" FontWeight="SemiBold"
                        Background="#E5E7EB" Foreground="#4B5563" BorderThickness="0" Margin="0,15,0,10" Click="btnHistory_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <ListBox x:Name="lstHistory" Height="100" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,5" Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Date}" FontWeight="SemiBold" Width="80" Foreground="#4B5563"/>
                                <TextBlock Text="Buy:" Foreground="#10B981" Margin="5,0,2,0"/>
                                <TextBlock Text="{Binding BuyRate}" FontWeight="Bold" Width="55"/>
                                <TextBlock Text="Sell:" Foreground="#EF4444" Margin="5,0,2,0"/>
                                <TextBlock Text="{Binding SellRate}" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,15,0,15"/>

                <TextBlock Text="TRANSACTION" FontSize="16" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Amount:" FontSize="14" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBox x:Name="txtTransactionAmount" Width="150" Height="35" FontSize="16" Padding="5" 
                         BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,10" HorizontalAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="btnBuy" Content="Buy Currency" Width="120" Height="40" FontSize="14" FontWeight="Bold" 
                            Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="btnBuy_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnSell" Content="Sell Currency" Width="120" Height="40" FontSize="14" FontWeight="Bold" 
                            Background="#EF4444" Foreground="White" BorderThickness="0" Click="btnSell_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,0,0,15"/>

                <TextBlock Text="CREATE ACCOUNT" FontSize="16" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBox x:Name="txtNewUser" Height="35" Margin="0,0,0,10" Padding="5" BorderBrush="#D1D5DB" ToolTip="New Username">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <PasswordBox x:Name="txtNewPass" Height="35" Margin="0,0,0,10" Padding="5" BorderBrush="#D1D5DB" ToolTip="New Password">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <Button x:Name="btnRegister" Content="Register Now" Height="35" FontSize="14" FontWeight="Bold" 
                        Foreground="White" Background="#10B981" BorderThickness="0" Click="btnRegister_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="15,30,30,30" Padding="40,30" 
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="USER LOGIN" FontSize="22" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Username:" FontSize="14" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLoginUser" Height="40" FontSize="16" Padding="10,6" 
                         BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Password:" FontSize="14" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtLoginPass" Height="40" FontSize="16" Padding="10,6" 
                             BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,20">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <Button x:Name="btnLogin" Content="Login" Height="40" FontSize="16" FontWeight="Bold" 
                        Foreground="White" Background="#F59E0B" BorderThickness="0" Click="btnLogin_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,25,0,20"/>

                <TextBlock Text="MY WALLET" FontSize="20" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Border Background="#F3F4F6" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Current PLN Balance" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtBalance" Text="Not logged in" FontSize="26" FontWeight="Bold" 
                                   Foreground="#10B981" HorizontalAlignment="Center" Margin="0,5,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBox x:Name="txtTopUpAmount" Width="90" Height="35" FontSize="14" Padding="5,6" 
                                     BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,10,0">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button x:Name="btnTopUp" Content="Add PLN" Width="80" Height="35" FontSize="13" FontWeight="Bold" 
                                    Background="#2563EB" Foreground="White" BorderThickness="0" Click="btnTopUp_Click" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="My Currencies" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <ListBox x:Name="lstWallet" Height="100" BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Margin="0,0,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding Currency}" FontWeight="Bold" Foreground="#1E3A8A" Width="50" FontSize="16"/>
                                <TextBlock Text="{Binding Amount}" Foreground="#F59E0B" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </Border>
    </Grid>
</Window>