<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="750" Width="900"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="30" Padding="40" 
                VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="NBP CURRENCY EXCHANGE" FontSize="22" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Currency Code (e.g., USD, EUR, GBP):" FontSize="14" Foreground="#4B5563" Margin="0,0,0,8"/>
                <TextBox x:Name="txtCurrencyCode" Height="42" FontSize="16" Padding="10,8" 
                         CharacterCasing="Upper" BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,25">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="btnGetRate" Content="Get Rate" Height="45" FontSize="16" FontWeight="Bold" 
                        Foreground="White" Background="#2563EB" BorderThickness="0" Click="btnGetRate_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,30,0,25"/>

                <TextBlock x:Name="txtResult" Text="Ready." FontSize="14" Margin="0,0,0,10" Foreground="#6B7280" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtBuyRate" Text="Buy (Bid): -" FontSize="18" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtSellRate" Text="Sell (Ask): -" FontSize="18" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center"/>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,30,0,25"/>

                <TextBlock Text="CREATE ACCOUNT" FontSize="18" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="New Username:" FontSize="13" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtNewUser" Height="35" Margin="0,0,0,15" Padding="5" BorderBrush="#D1D5DB">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="New Password:" FontSize="13" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtNewPass" Height="35" Margin="0,0,0,20" Padding="5" BorderBrush="#D1D5DB">
                </PasswordBox>

                <Button x:Name="btnRegister" Content="Register Now" Height="40" FontSize="14" FontWeight="Bold" 
                        Foreground="White" Background="#10B981" BorderThickness="0" Click="btnRegister_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="0,30,30,30" Padding="40" 
                VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="USER LOGIN" FontSize="22" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Username:" FontSize="14" Foreground="#4B5563" Margin="0,0,0,8"/>
                <TextBox x:Name="txtLoginUser" Height="42" FontSize="16" Padding="10,8" 
                         BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Password:" FontSize="14" Foreground="#4B5563" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtLoginPass" Height="42" FontSize="16" Padding="10,8" 
                             BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,25">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <Button x:Name="btnLogin" Content="Login" Height="45" FontSize="16" FontWeight="Bold" 
                        Foreground="White" Background="#F59E0B" BorderThickness="0" Click="btnLogin_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,30,0,25"/>

                <TextBlock Text="MY WALLET" FontSize="18" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="#F3F4F6" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Current PLN Balance" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtBalance" Text="Not logged in" FontSize="24" FontWeight="Bold" 
                                   Foreground="#10B981" HorizontalAlignment="Center" Margin="0,10,0,15"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBox x:Name="txtTopUpAmount" Width="100" Height="35" FontSize="14" Padding="5,6" 
                                     BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,10,0">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button x:Name="btnTopUp" Content="Add PLN" Width="90" Height="35" FontSize="14" FontWeight="Bold" 
                                    Background="#10B981" Foreground="White" BorderThickness="0" Click="btnTopUp_Click" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Window>