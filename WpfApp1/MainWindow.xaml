<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="850" Width="1000"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="25,30,12,30" Padding="35,25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="NBP MARKET DATA" FontSize="22" FontWeight="Bold" 
                           Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Currency Code (USD, EUR, GBP):" FontSize="13" Foreground="#6B7280" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCurrencyCode" Height="40" FontSize="16" Padding="10,6" 
                         CharacterCasing="Upper" BorderBrush="#D1D5DB" BorderThickness="1.5" Margin="0,0,0,12" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="btnGetRate" Content="Fetch Live Rates" Height="40" FontSize="15" FontWeight="Bold" 
                        Foreground="White" Background="#2563EB" BorderThickness="0" Click="btnGetRate_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Margin="0,20,0,10">
                    <TextBlock x:Name="txtResult" Text="System Ready" FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <Border Background="#F9FAFB" Padding="15" CornerRadius="8" BorderBrush="#F3F4F6" BorderThickness="1">
                        <StackPanel>
                            <UniformGrid Columns="2">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="BUY (BID)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtBuyRate" Text="0.0000" FontSize="22" FontWeight="ExtraBold" Foreground="#10B981"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="SELL (ASK)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtSellRate" Text="0.0000" FontSize="22" FontWeight="ExtraBold" Foreground="#EF4444"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button x:Name="btnHistory" Content="📊 Show 7-Day History" Height="32" Width="160" FontSize="12" FontWeight="SemiBold"
                        Background="#F3F4F6" Foreground="#4B5563" BorderThickness="0" Margin="0,10,0,10" Click="btnHistory_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="16"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <ListBox x:Name="lstHistory" Height="130" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,5" Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Date}" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="B:" Foreground="#10B981" Margin="0,0,4,0" FontSize="11"/>
                                        <TextBlock Text="{Binding BuyRate}" FontWeight="Bold" Foreground="#10B981"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="S:" Foreground="#EF4444" Margin="0,0,4,0" FontSize="11"/>
                                        <TextBlock Text="{Binding SellRate}" FontWeight="Bold" Foreground="#EF4444"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Separator Height="20" Background="Transparent"/>

                <Border Background="#1E3A8A" CornerRadius="10" Padding="20,15">
                    <StackPanel>
                        <TextBlock Text="QUICK TRADE" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtTransactionAmount" Width="140" Height="35" FontSize="18" FontWeight="Bold" Padding="5" 
                                 BorderThickness="0" Margin="0,0,0,15" HorizontalAlignment="Center" VerticalContentAlignment="Center" TextAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <UniformGrid Columns="2">
                            <Button x:Name="btnBuy" Content="BUY" Height="40" FontWeight="Bold" Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,5,0" Click="btnBuy_Click" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="btnSell" Content="SELL" Height="40" FontWeight="Bold" Background="#EF4444" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="btnSell_Click" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="12,30,25,30" Padding="35,25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="ACCOUNT ACCESS" FontSize="18" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBox x:Name="txtLoginUser" Height="35" Margin="0,0,0,8" Padding="10,5" BorderBrush="#D1D5DB" Tag="Username">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <PasswordBox x:Name="txtLoginPass" Height="35" Margin="0,0,0,12" Padding="10,5" BorderBrush="#D1D5DB">
                    <PasswordBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
                <Button x:Name="btnLogin" Content="Sign In" Height="38" FontWeight="Bold" Foreground="White" Background="#F59E0B" BorderThickness="0" Click="btnLogin_Click" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Separator Height="30" Background="Transparent"/>

                <TextBlock Text="VIRTUAL WALLET" FontSize="20" FontWeight="Bold" Foreground="#1E3A8A" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <Border Background="#F9FAFB" CornerRadius="12" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="PLN BALANCE" FontSize="11" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtBalance" Text="0.00 PLN" FontSize="32" FontWeight="ExtraBold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,5"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtTopUpAmount" Height="35" Margin="0,0,8,0" Padding="8,5" BorderBrush="#D1D5DB">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button x:Name="btnTopUp" Grid.Column="1" Content="Add Funds" Width="90" Height="35" FontWeight="Bold" Background="#2563EB" Foreground="White" BorderThickness="0" Click="btnTopUp_Click" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Asset Holdings" FontSize="13" FontWeight="Bold" Foreground="#4B5563" Margin="0,20,0,8"/>
                <ListBox x:Name="lstWallet" Height="140" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F3F4F6" Margin="0,0,0,6" CornerRadius="6" Padding="12,8">
                                <DockPanel>
                                    <TextBlock Text="{Binding Currency}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="15" DockPanel.Dock="Left"/>
                                    <TextBlock Text="{Binding Amount}" FontWeight="Bold" Foreground="#F59E0B" FontSize="15" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Expander Header="Create New Account" Margin="0,15,0,0" Foreground="#6B7280" FontSize="12">
                    <StackPanel Margin="10">
                        <TextBox x:Name="txtNewUser" Height="30" Margin="0,0,0,5" Padding="5" BorderBrush="#D1D5DB" Tag="New Username"/>
                        <PasswordBox x:Name="txtNewPass" Height="30" Margin="0,0,0,8" Padding="5" BorderBrush="#D1D5DB"/>
                        <Button x:Name="btnRegister" Content="Register" Height="30" Background="#10B981" Foreground="White" BorderThickness="0" Click="btnRegister_Click"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>