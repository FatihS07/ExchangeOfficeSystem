<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://schemas.datacontract.org/2004/07/MyWcfService" elementFormDefault="qualified" targetNamespace="http://schemas.datacontract.org/2004/07/MyWcfService" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:complexType name="ExchangeRateData">
    <xs:sequence>
      <xs:element minOccurs="0" name="BuyRate" type="xs:double" />
      <xs:element minOccurs="0" name="Currency" nillable="true" type="xs:string" />
      <xs:element minOccurs="0" name="SellRate" type="xs:double" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="ExchangeRateData" nillable="true" type="tns:ExchangeRateData" />
  <xs:complexType name="ArrayOfWalletItem">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="WalletItem" nillable="true" type="tns:WalletItem" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="ArrayOfWalletItem" nillable="true" type="tns:ArrayOfWalletItem" />
  <xs:complexType name="WalletItem">
    <xs:sequence>
      <xs:element minOccurs="0" name="Amount" type="xs:decimal" />
      <xs:element minOccurs="0" name="Currency" nillable="true" type="xs:string" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="WalletItem" nillable="true" type="tns:WalletItem" />
  <xs:complexType name="ArrayOfHistoricalRate">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="HistoricalRate" nillable="true" type="tns:HistoricalRate" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="ArrayOfHistoricalRate" nillable="true" type="tns:ArrayOfHistoricalRate" />
  <xs:complexType name="HistoricalRate">
    <xs:sequence>
      <xs:element minOccurs="0" name="BuyRate" type="xs:double" />
      <xs:element minOccurs="0" name="Date" nillable="true" type="xs:string" />
      <xs:element minOccurs="0" name="SellRate" type="xs:double" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="HistoricalRate" nillable="true" type="tns:HistoricalRate" />
</xs:schema>